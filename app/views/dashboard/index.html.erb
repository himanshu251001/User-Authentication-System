<body class="bg-gray-100 min-h-screen flex flex-col items-center justify-center">
  <div class="bg-white shadow-md rounded-lg p-8 max-w-md w-full">
    <h2 class="text-3xl font-semibold text-center mb-4">Welcome, <%= @user.first_name %> <%= @user.last_name %>!</h2>

    <div class="flex justify-center mb-4">
      <% if current_user.icon.attached? %>
        <%= image_tag current_user.icon, class: "w-24 h-24 rounded-full border-2 border-gray-300 shadow-sm" %>
      <% else %>
        <%= image_tag "/images/default-icon.png", class: "w-24 h-24 rounded-full border-2 border-gray-300 shadow-sm" %>
      <% end %>
    </div>

    <div class="bg-gray-50 p-4 rounded-md shadow-inner">
      <p class="text-lg"><strong>Email:</strong> <%= @user.email %></p>
      <p class="text-lg"><strong>Date of Birth:</strong> <%= @user.dob.strftime("%d %B %Y") if @user.dob %></p>
      <p class="text-lg"><strong>Gender:</strong> <%= @user.gender.capitalize if @user.gender %></p>
    </div>

    <% if current_user == @user %>
      <div class="flex flex-col gap-2 mt-4">
        <%= link_to "Edit Profile", edit_user_registration_path, class: "block text-center bg-blue-500 text-white py-2 rounded-md font-medium hover:bg-blue-600" %>
      </div>
    <% end %>

    <div class="flex flex-col gap-2 mt-4">
      <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "block text-center bg-red-500 text-white py-2 rounded-md font-medium hover:bg-red-600" %>
    </div>
  </div>
</body>
