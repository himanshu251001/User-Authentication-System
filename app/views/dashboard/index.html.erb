

<body class="bg-blue-900  p-4">

    <div class="bg-gray-100 p-6 rounded-lg shadow-lg w-full ">
        <div class="flex justify-between pr-6 my-4">
<h1 class="text-blue-900 text-4xl font-bold">Dashboard</h1>
         <%= button_to "Sign out", destroy_user_session_path, method: :delete, data: { turbo_method: :delete }, class: " text-center bg-red-500  text-white px-4 py-2 rounded-md font-medium hover:bg-red-600" %>
        </div>
        <!-- Profile Section -->
        <div class="bg-white flex flex-col gap-2 shadow-md rounded-md p-6 relative">
<div class="flex flex-row flex-wrap items-center justify-between gap-2">

            
            
            <div class="flex flex-row items-center flex-wrap gap-2">
                <div >
                     <% if current_user.icon.attached? %>
                             <%= image_tag current_user.icon,class:"w-20 h-20 text-white flex items-center justify-center rounded-full text-2xl font-bold" %>
                    <% else %>
                   <%= image_tag "/images/default-icon.png",class:"w-20 h-20 text-white flex items-center justify-center rounded-full text-2xl font-bold"%>
                       <% end %>
                </div>
                <div >
                    <h2 class="text-2xl font-semibold"><%= @user.first_name %> <%= @user.last_name %>!</h2>
                    <div class="flex items-center text-gray-600 space-x-2">
                        <span>📍</span> 
                        <span><%= @user.email %></span>
                    </div>
                </div>
                </div>
                                         <%= button_to "Edit Profile", edit_user_registration_path, method: :get, class:"bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700" %>

            </div>
            
            <!-- Job Details -->
            <div class="mt-4 bg-gray-50 p-4 rounded-md shadow-inner flex flex-col text-gray-700">
                <p><strong>DATE OF Birth:</strong> - <%= @user.dob.strftime("%d %B %Y") if @user.dob %></p>
                <p><strong>GENDER:</strong> - <%= @user.gender.capitalize if @user.gender %></p>
                <p><strong>ROLE:</strong> - <%=@user.role.capitalize %></p>
             
            </div>
        </div>

        <!-- Review Section -->
        <div class="mt-6 bg-blue-900 p-4 rounded-md">
            <div class="bg-white p-6 rounded-md shadow-md">
                <div class="flex items-center space-x-4">
                    <div class="w-6 h-6 bg-blue-600 rounded-full"></div>
                    <div class="flex-1 bg-gray-200 h-6 rounded-md"></div>
                </div>
                <div class="mt-4 bg-gray-100 p-6 rounded-md shadow">
                    <p class="text-gray-700"></p>
                    <div class="flex justify-end mt-4">
                    <div class="flex flex-row h-24 justify-end mt-4">
                    
                    </div>
                  
                    </div>
                </div>
            </div>
        </div>

    </div>
  </div>
</body>