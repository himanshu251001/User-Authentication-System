<body class="bg-gray-100 h-screen flex justify-center items-center p-6">
  <div class="bg-white shadow-md rounded-lg p-6 w-full max-w-md">
    <h2 class="text-2xl font-semibold text-center mb-4">Change Your Password</h2>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-4" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div>
        <%= f.label :password, "New Password", class: " text-lg font-medium text-gray-700" %>
        <% if @minimum_password_length %>
          <em class="text-xs text-gray-500">(<%= @minimum_password_length %> characters minimum)</em>
        <% end %>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "mt-1  w-full px-4 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-2 focus:ring-blue-500 focus:outline-none" %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirm New Password", class: " text-lg font-medium text-gray-700" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "mt-1  w-full px-4 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-2 focus:ring-blue-500 focus:outline-none" %>
      </div>

      <div class="mt-4">
        <%= f.submit "Change My Password", class: "w-full bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded shadow-md" %>
      </div>
    <% end %>

    <div class="mt-4 text-center flex flex-col gap-2">
      <%= render "devise/shared/links",class:"focus:underline" %>
    </div>
  </div>
</body>
